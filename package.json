{
  "name": "vocab-annihilation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:vocab": "node scripts/build-vocab.mjs",
    "predev": "npm run build:vocab",
    "dev": "vite --host 0.0.0.0",
    "optimize:sprites": "node scripts/optimize-sprites.mjs",
    "prebuild": "npm run build:vocab && npm run optimize:sprites",
    "build": "tsc --noEmit && vite build",
    "pretypecheck": "npm run build:vocab",
    "predeploy": "pnpm run build",
    "deploy": "node -e \"require('gh-pages').clean()\" && gh-pages -d dist",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:vocab",
    "test": "vitest run",
    "pretest:e2e": "npm run build:vocab",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "phaser": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "gh-pages": "^6.3.0",
    "sharp": "^0.34.5",
    "typescript": "latest",
    "vitest": "latest"
  }
}